# MASF & Partners frontend configuration.
# Copy to frontend/.env — Vite loads it automatically. All values optional.

# Production domain. Used at build time for sitemap.xml, robots.txt and the
# og:url / og:image meta tags. Example: https://www.masfpartners.com.ng
# VITE_SITE_URL=

# Backend origin, ONLY when the frontend is hosted separately from the API
# (e.g. Netlify + Railway). Leave unset for the dev proxy or single-server
# deployment. Example: https://api.masfpartners.com.ng
# VITE_API_BASE_URL=

# Privacy-friendly analytics (Plausible). Set to the site's domain to enable.
# VITE_PLAUSIBLE_DOMAIN=masfpartners.com.ng
# Self-hosted Plausible? Point this at your script URL.
# VITE_PLAUSIBLE_SRC=

# Cloudflare Turnstile anti-spam (pairs with MASF_TURNSTILE_SECRET on the
# backend). Free at https://dash.cloudflare.com -> Turnstile.
# VITE_TURNSTILE_SITE_KEY=
