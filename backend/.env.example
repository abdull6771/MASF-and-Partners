# MASF & Partners backend configuration.
# Copy to backend/.env — the app auto-loads it at startup (real environment
# variables take precedence). All values are optional; the API runs with
# sensible defaults for local development.

# --- Storage --------------------------------------------------------------
# SQLite database location (default: backend/data/submissions.db)
# MASF_DB_PATH=
# Attachment upload folder (default: backend/data/uploads)
# MASF_UPLOAD_DIR=
# Max attachment size in MB (default: 10)
# MASF_MAX_ATTACHMENT_MB=10

# --- Access ---------------------------------------------------------------
# Comma-separated origins allowed by CORS (default: Vite dev server)
# MASF_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Set to enable GET /api/submissions and the /admin page
# (sent as the X-Admin-Token header)
# MASF_ADMIN_TOKEN=change-me

# --- Anti-spam ------------------------------------------------------------
# Contact-form rate limit: max submissions per window per IP
# MASF_RATE_LIMIT_MAX=5
# MASF_RATE_LIMIT_WINDOW_SECONDS=600
# Cloudflare Turnstile secret key. When set, every submission must pass the
# Turnstile challenge (also set VITE_TURNSTILE_SITE_KEY in frontend/.env).
# MASF_TURNSTILE_SECRET=

# --- Email notifications ---------------------------------------------------
# The form works without these; submissions are always stored in SQLite.
# Configure SMTP to also receive each enquiry by email. For Gmail, create an
# App Password (Google Account -> Security -> 2-Step Verification).
# MASF_SMTP_HOST=smtp.gmail.com
# MASF_SMTP_PORT=587
# MASF_SMTP_USER=masfpartnerslimited@gmail.com
# MASF_SMTP_PASSWORD=app-password-here
# MASF_SMTP_FROM=masfpartnerslimited@gmail.com
# MASF_NOTIFY_TO=masfpartnerslimited@gmail.com
